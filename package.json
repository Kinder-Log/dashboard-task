{
  "name": "deshbord-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:backend": "npm run --prefix backend dev",
    "dev:frontend": "npm run --prefix frontend dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:backend": "npm run --prefix backend build",
    "build:frontend": "npm run --prefix frontend build",
    "test:backend": "npm run --prefix backend test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
